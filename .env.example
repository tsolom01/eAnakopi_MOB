# API base URL — backend repo: eAnakopi_APIs
#
# Pick the line that matches how you run the app:
# iOS Simulator:     http://localhost:3000
# Android Emulator:  http://10.0.2.2:3000
# Physical device:   http://YOUR_MAC_IP:3000  (find IP: ipconfig getifaddr en0)
#
# If unset, defaults are chosen automatically (localhost on iOS, 10.0.2.2 on Android).
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
